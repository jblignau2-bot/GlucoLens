{
  "expo": {
    "name": "GlucoLens",
    "slug": "glucolens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "glucolens",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d9488"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.glucolens.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GlucoLens uses your camera to photograph meals for AI nutritional analysis.",
        "NSPhotoLibraryUsageDescription": "GlucoLens accesses your photo library so you can select meal photos for analysis."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d9488"
      },
      "package": "com.glucolens.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "GlucoLens uses your camera to photograph meals for AI nutritional analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GlucoLens accesses your photos to let you select meal images for analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1965294e-a9ff-476b-a029-019489e5f1e1"
      }
    }
  }
}
